rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Catch-all default deny to enforce zero-trust security
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable Global Security Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "saharat2@soengsang.ac.th" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Rules for individual collections
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /classrooms/{classroomId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /examQuestions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
      allow update: if isSignedIn() && (existing().studentId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().studentId == request.auth.uid || isAdmin());
    }

    // Supporting admin document paths
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if request.auth.token.email == "saharat2@soengsang.ac.th";
    }
  }
}
